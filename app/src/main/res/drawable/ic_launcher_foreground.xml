<?xml version="1.0" encoding="utf-8"?>
<!--
  OpenRower launcher icon foreground — 108×108dp adaptive-icon canvas.
  Safe zone: 66dp circle (r=33) centred at (54,54) — guaranteed visible on all launchers.

  Two modern sculling oars, vertical, parallel:
    Left  oar centre (48,54): handle top y=28, blade tip corner ~(41,81) → dist≈30 ≤ 33 ✓
    Right oar centre (60,54): rotated 180° → blade tip corner ~(67,27) → dist≈30 ≤ 33 ✓
    Blade tapers from shaft width at top → 12dp wide at mid → asymmetric curved tip.

  "OR" monogram in a single alpha=0.85 group (amber #FFB300) so the diagonal leg
  and bar share the same offscreen composite — no double-paint transparency artefact.
    O: perfect circle r=8, stroke 4 px, centre (44,54). Visible y-extent: 44–64 (20 px).
    R: bar bottom→top then D-bow arc (rx=12 ry=4), leg to (72,62).
       Cap height identical to O: top cap edge y=44, bottom cap edge y=64.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Left oar · handle upper-left, asymmetric hatchet blade lower-left ── -->
    <group
        android:translateX="48"
        android:translateY="54">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
              M0,-26 Q3,-26 3,-23 L3,-20 L2,-16 L2,12
              L3,23
              L-7,28
              L-7,14
              Q-3,11 -2,11
              L-2,-16 L-3,-20 L-3,-23
              Q-3,-26 0,-26 Z"/>
    </group>

    <!-- ── Right oar · same path rotated 180° ────────────────────────────── -->
    <group
        android:translateX="60"
        android:translateY="54"
        android:rotation="180">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="
              M0,-26 Q3,-26 3,-23 L3,-20 L2,-16 L2,12
              L3,23
              L-7,28
              L-7,14
              Q-3,11 -2,11
              L-2,-16 L-3,-20 L-3,-23
              Q-3,-26 0,-26 Z"/>
    </group>

    <!-- ── "OR" monogram · single group so alpha composites once ─────────── -->
    <group android:alpha="0.85">

        <!-- O · circle r=8, stroke 4 px, centre (44,54)                     -->
        <!--   outer x=34–54, outer y=44–64                                   -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFB300"
            android:strokeWidth="4"
            android:pathData="M36,54 A8,8 0 1,1 52,54 A8,8 0 1,1 36,54 Z"/>

        <!-- R bar (y=62→46) + D-bow (rx=12 ry=4 → bow centre x=72, outer 74) -->
        <!--   Top cap edge y=44, bottom cap edge y=64  — matches O exactly   -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFB300"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M60,62 L60,46 A12,4 0 0,1 60,54"/>

        <!-- R diagonal leg                                                   -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FFB300"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:pathData="M60,54 L72,62"/>

    </group>

</vector>
