<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (dark rowing monitor UI). -->
    <style name="Theme.OpenRower" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#4FC3F7</item>
        <item name="colorSecondaryVariant">#0288D1</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">#0A1520</item>
        <item name="android:windowBackground">#0D1B2A</item>
    </style>

    <style name="Theme.OpenRower.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.OpenRower.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.OpenRower.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>