<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_setup">

    <fragment
        android:id="@+id/nav_setup"
        android:name="com.naibaf7.openrower.ui.setup.SetupFragment"
        android:label="Workout Setup"
        tools:layout="@layout/fragment_setup">

        <action
            android:id="@+id/action_setup_to_workout"
            app:destination="@id/nav_workout"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_setup_to_settings"
            app:destination="@id/nav_settings"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />

        <action
            android:id="@+id/action_setup_to_history"
            app:destination="@id/nav_history"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/nav_workout"
        android:name="com.naibaf7.openrower.ui.workout.WorkoutFragment"
        android:label="Workout"
        tools:layout="@layout/fragment_workout">

        <argument
            android:name="config"
            app:argType="com.naibaf7.openrower.model.WorkoutConfig"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.naibaf7.openrower.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/nav_history"
        android:name="com.naibaf7.openrower.ui.history.HistoryFragment"
        android:label="Training History"
        tools:layout="@layout/fragment_history">

        <action
            android:id="@+id/action_history_to_detail"
            app:destination="@id/nav_workout_detail"
            app:enterAnim="@anim/nav_default_enter_anim"
            app:exitAnim="@anim/nav_default_exit_anim"
            app:popEnterAnim="@anim/nav_default_pop_enter_anim"
            app:popExitAnim="@anim/nav_default_pop_exit_anim" />
    </fragment>

    <fragment
        android:id="@+id/nav_workout_detail"
        android:name="com.naibaf7.openrower.ui.history.WorkoutDetailFragment"
        android:label="Workout Detail"
        tools:layout="@layout/fragment_workout_detail">

        <argument
            android:name="workoutId"
            app:argType="long" />
    </fragment>

</navigation>
