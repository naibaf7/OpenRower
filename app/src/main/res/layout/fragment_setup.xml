<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OpenRower"
            android:textSize="32sp"
            android:textColor="#ECEFF1"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Workout Setup"
            android:textSize="16sp"
            android:textColor="#90A4AE"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- ── Machine Profile ────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Machine"
            android:textColor="#90A4AE"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_machine"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="16dp" />

        <!-- ── Workout Mode ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Workout Mode"
            android:textColor="#90A4AE"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_mode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="16dp" />

        <!-- ── Distance mode ───────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Target Distance (meters)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/edit_target_distance"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="2000"
                android:textColor="#ECEFF1"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- ── Time mode ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Target Time"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/edit_target_minutes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:text="20"
                    android:textColor="#ECEFF1"
                    android:background="@drawable/edit_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="min"
                    android:textColorHint="#546E7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text=" : "
                    android:textColor="#90A4AE"
                    android:textSize="20sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/edit_target_seconds"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:text="00"
                    android:textColor="#ECEFF1"
                    android:background="@drawable/edit_bg"
                    android:paddingHorizontal="12dp"
                    android:hint="sec"
                    android:textColorHint="#546E7A" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Target pace mode ────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_target"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Target Pace (min:sec per 500m)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/edit_target_pace"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="text"
                android:text="2:00"
                android:textColor="#ECEFF1"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- ── FREE mode sliding window ────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_window"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chart Window (seconds)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/edit_window_seconds"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="300"
                android:textColor="#ECEFF1"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- ── Split length (mode-aware) ──────────────────────────────── -->
        <LinearLayout
            android:id="@+id/layout_split_meters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Split Distance (meters)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/edit_split_meters"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="500"
                android:textColor="#ECEFF1"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_split_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Split Duration (seconds)"
                android:textColor="#90A4AE"
                android:textSize="12sp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/edit_split_seconds"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:inputType="number"
                android:text="60"
                android:textColor="#ECEFF1"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- ── Rowing Device ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rowing Device (Bluetooth)"
                android:textColor="#90A4AE"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_refresh_devices"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Refresh"
                android:textSize="11sp"
                android:backgroundTint="#1E3A5F"
                android:textColor="#90A4AE" />
        </LinearLayout>

        <Spinner
            android:id="@+id/spinner_rowing_device"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="16dp" />

        <!-- ── HR Device ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heart Rate Monitor (BLE)"
            android:textColor="#90A4AE"
            android:textSize="12sp"
            android:paddingBottom="4dp" />

        <Spinner
            android:id="@+id/spinner_hr_device"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:layout_marginBottom="16dp" />

        <!-- ── Test Mode ───────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Test Mode (simulated data)"
                android:textColor="#90A4AE"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_test_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── Action Buttons ──────────────────────────────────────── -->
        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START WORKOUT"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="0dp">

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Settings"
                android:backgroundTint="#1E3A5F"
                android:textColor="#90A4AE"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="History"
                android:backgroundTint="#1E3A5F"
                android:textColor="#90A4AE" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
