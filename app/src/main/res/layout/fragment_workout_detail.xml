<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- ── Toolbar ── -->
    <LinearLayout
        android:id="@+id/layout_toolbar_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#060E16">

        <TextView
            android:id="@+id/txt_detail_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="12 Apr 2026, 07:30"
            android:textColor="#ECEFF1"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_delete_workout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Delete"
            android:textSize="12sp"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="12dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── Summary card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0A1520"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txt_detail_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:letterSpacing="0.10"
                    android:paddingBottom="12dp" />

                <!-- Duration + Distance -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="DURATION" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_duration"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="20:00" android:textColor="#4FC3F7" android:textSize="28sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="DISTANCE" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_dist"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="2000 m" android:textColor="#ECEFF1" android:textSize="28sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A2E45" android:layout_marginBottom="12dp"/>

                <!-- Avg Pace -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="AVG PACE /500m" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_pace"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="2:00" android:textColor="#4FC3F7" android:textSize="22sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A2E45" android:layout_marginBottom="12dp"/>

                <!-- Power + Calories -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="AVG POWER" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_power"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="150 W avg" android:textColor="#66BB6A" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="CALORIES" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_cals"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="250.0 kcal" android:textColor="#FFA726" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- HR + Strokes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="AVG HEART RATE" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_hr"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="145 bpm avg" android:textColor="#EF5350" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="STROKES" android:textColor="#546E7A" android:textSize="9sp" android:letterSpacing="0.10"/>
                        <TextView android:id="@+id/txt_detail_strokes"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="120 strokes" android:textColor="#B0BEC5" android:textSize="18sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Splits header ── -->
            <TextView
                android:id="@+id/txt_splits_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Splits"
                android:textColor="#546E7A"
                android:textSize="11sp"
                android:letterSpacing="0.10"
                android:paddingBottom="8dp" />

            <!-- ── Split column headers ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="4dp">

                <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="#" android:textColor="#546E7A" android:textSize="10sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Time" android:textColor="#546E7A" android:textSize="10sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Dist" android:textColor="#546E7A" android:textSize="10sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="/500m" android:textColor="#546E7A" android:textSize="10sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Power" android:textColor="#546E7A" android:textSize="10sp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="HR" android:textColor="#546E7A" android:textSize="10sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A2E45" android:layout_marginBottom="4dp"/>

            <!-- Split rows -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_splits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
